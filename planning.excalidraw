    {
      "id": "CGeLtEDEZYdQD9r3nIfXj",
      "type": "text",
      "x": 1805.6793773510833,
      "y": -43.59952951383093,
      "width": 303.73980712890625,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
