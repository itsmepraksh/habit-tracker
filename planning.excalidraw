      "roundness": null,
      "seed": 1297582055,
      "version": 409,
      "versionNonce": 836789449,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778265057232,
      "link": null,
      "locked": false,
      "text": "frontend me 10 task \nlisted hai , to abhi \nusme se usne 5 tick\nkiye hai to ek timer \nlaga rahega ki day end \nke baad 1 hour ke baad\nbts me data jo hai calculate \nhoga aur backend me wo saare \ntick wale ka count jayega aur\nvalue db me store hoga. to fir \ngraph me 10 me se jitna task \ncomplete kiya usne usko uske \nhisab se point milega.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "frontend me 10 task \nlisted hai , to abhi \nusme se usne 5 tick\nkiye hai to ek timer \nlaga rahega ki day end \nke baad 1 hour ke baad\nbts me data jo hai calculate \nhoga aur backend me wo saare \ntick wale ka count jayega aur\nvalue db me store hoga. to fir \ngraph me 10 me se jitna task \ncomplete kiya usne usko uske \nhisab se point milega.",
      "autoResize": true,
      "lineHeight": 1.25
    },
